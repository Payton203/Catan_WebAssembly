@page "/Layout_Partida"
@using CATAN_WebAssembly.Pages.Partida
@using MudBlazor
@inject Personalizacion_Pagina Config
@implements IDisposable

<div class="catan-board" style="position: relative;">
    <HexGrid Cells="_celdas"
             RowLayout="new[] { 3, 4, 5, 4, 3 }"
             GapRatio="Config.Valor_Gapratio"
             SizeScale="Config.Valor_SizeScale"
             AutoSize="true"
             OnCellClick="HandleCellClick" />

    <CatanOverlay RowLayout="new[] { 3, 4, 5, 4, 3 }"
                  SizeScale="Config.Valor_SizeScale"
                  GapRatio="Config.Valor_Gapratio"
                  OffsetX="Config.OffsetX"
                  OffsetY="Config.OffsetY"
                  OverlayScale="Config.OverlayScale"
                  OnVertexClick="HandleVertexClick"
                  OnEdgeClick="HandleEdgeClick"
                  OnGeometryReady="HandleGeometryReady" />
</div>

@code {
    // ─── Se ingresan los datos de las casillas ─────────────────────────────────────────────────

    // private List<HexCell> _celdas = Enumerable.Range(1, 19)
    //     .Select(i => new HexCell
    //     {
    //         Id = i.ToString(),
    //         Label = i.ToString()
    //     })
    //     .ToList();

    // esto es la funcion de abajo, pero mas compacta, se instancia automaticamente sin necesidad de ser llamada en OnInitialized()
    // uso la otra porque la entiendo mas y por eso la puedo modificar con mas precision

    private List<HexCell> _celdas = new List<HexCell>();

    private List<HexCell> CrearCeldas()
    {
        List<HexCell> resultado = new List<HexCell>();

        for (int i = 1; i <= 19; i++)
        {
            HexCell celda = new HexCell();
            celda.Id = i.ToString();
            celda.Label = i.ToString();
            resultado.Add(celda);
        }

        return resultado;
    }

    // ─── Se ingresan los datos de los vertices y de los hexagonos ─────────────────────────────────────────────────

    private List<HexVertex> _vertices = new();
    private List<HexEdge> _edges = new();

    private void HandleGeometryReady((List<HexVertex> Vertices, List<HexEdge> Edges) tupla)
    {
        _vertices = tupla.Vertices;
        _edges = tupla.Edges;
        //tupla contiene la info de ambas listas
        AsignarIdsVertices();
        AsignarIdsEdges();
        Console.WriteLine($"Vertices asignados: {_vertices.Count}, primero: {_vertices[0].Id}, último: {_vertices[^1].Id}");
        for (int i = 0; i < _vertices.Count; i++)
        {
            switch (_vertices[i].Id)
            {
                case 1:
                    _vertices[i].Structure = StructureType.Settlement;
                    _vertices[i].PlayerColor = "Yellow";
                    break;
                case 2:
                    _vertices[i].Structure = StructureType.City;
                    _vertices[i].PlayerColor = "Yellow";
                    break;
            }
        }
        for (int i = 0; i < _edges.Count; i++)
        {
            switch (_edges[i].Id)
            {
                case 1:
                    _edges[i].HasRoad = true;
                    _edges[i].PlayerColor = "Yellow";
                    break;
            }
        }
    }

    private void AsignarIdsVertices()
    {
        for (int i = 0; i < _vertices.Count; i++)
        {
            _vertices[i].Id = i;
        }
    }

    private void AsignarIdsEdges()
    {
        for (int i = 0; i < _edges.Count; i++)
        {
            _edges[i].Id = i;
        }
    }

    // ─── Evento cuando cambia algo, respecto a la configuracion ─────────────────────────────────────────────────
    protected override void OnInitialized() //cuando se renderiza la pagina, este metodo se ejecuta
    {
        Config.OnChange += HandleChange;
        //se suscribe, para que cada vez que algún valor cambie, invoque el metodo HandleChange

        _celdas = CrearCeldas(); // crea celdas
    }

    private void HandleChange()
    {
        StateHasChanged();
        // vuelve a renderizar el Layout
    }

    public void Dispose() 
    {
        Config.OnChange -= HandleChange;
        /*se desuscribe del evento, para que Config.OnChange, para que no quede apuntando a esta pagina,
        permitiendo que se desrenderize completamente, previniendo memory leaks*/
    }
    //se llama automaticamente cuando el componente se destruye, como cuando se cambia de pagina.
    

    private void HandleCellClick(HexCell cell)
    {
        Console.WriteLine($"Clickeaste la celda {cell.Id}");
    }

    private void HandleSelection(List<HexCell> seleccionadas)
    {
        Console.WriteLine($"Seleccionadas: {string.Join(", ", seleccionadas.Select(c => c.Id))}");
    }

    private void HandleVertexClick(HexVertex vertex)
    {
        Console.WriteLine($"Click - Position_Id: {vertex.Position_Id} - Id: {vertex.Id}");
        // por ahora vacío, después acá va la lógica de colocar asentamientos
    }

    private void HandleEdgeClick(HexEdge edge)
    {
        Console.WriteLine($"Clickeaste la arista {edge.Id}");
        // por ahora vacío, después acá va la lógica de colocar carreteras
    }
}