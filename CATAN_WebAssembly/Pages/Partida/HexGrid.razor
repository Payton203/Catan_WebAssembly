@implements IAsyncDisposable
@inject IJSRuntime JS

<div class="hex-grid" @ref="_gridRef">
    @for (int r = 0; r < _rows.Count; r++)
    {
        var rowCols = _rows[r].Count;
        var rowIndent = GetRowIndent(rowCols);
        var isFirst = r == 0;

        <div class="hex-row"
             style="margin-left: @rowIndent;
            margin-top: @(isFirst ? "0px" : _computedRowMargin);">
            @foreach (var cell in _rows[r])
            {
                <div class="hex @(IsSelected(cell) ? "hex--selected" : "")"
                     style="width: @_computedHexSize;
                    margin: 0 @_computedHalfGap;
                    @(cell.BackgroundColor is not null ? $"--hex-bg: {cell.BackgroundColor};" : "")"
                     @onclick="() => SelectCell(cell)">
                    <span class="hex__label">@cell.Label</span>
                </div>
            }
        </div>
    }
</div>

@code {
    // ─── Parámetros ────────────────────────────────────────────────────────────

    [Parameter, EditorRequired]
    public List<HexCell> Cells { get; set; } = new();

    [Parameter]
    public int[] RowLayout { get; set; } = { 3, 4, 5, 4, 3 };

    [Parameter]
    public double GapRatio { get; set; } = 0.05;

    [Parameter]
    public bool AutoSize { get; set; } = true;

    [Parameter]
    public string HexSize { get; set; } = "100px";

    [Parameter]
    public double SizeScale { get; set; } = 1.0;

    [Parameter]
    public bool MultiSelect { get; set; } = false;

    [Parameter] public EventCallback<HexCell> OnCellClick { get; set; }
    [Parameter] public EventCallback<List<HexCell>> OnSelectionChanged { get; set; }

    /// <summary>
    /// Se dispara cada vez que el tamaño del grid se recalcula.
    /// CatanBoard lo usa para recomputer vértices y aristas.
    /// </summary>
    [Parameter] public EventCallback<BoardGeometry> OnGeometryChanged { get; set; }

    // ─── Estado interno ────────────────────────────────────────────────────────

    private ElementReference _gridRef;
    private DotNetObjectReference<HexGrid>? _selfRef;
    private List<List<HexCell>> _rows = new();
    private readonly HashSet<string> _selectedIds = new();

    private double _hexSizePx = 100;
    private double _gapPx = 5;
    private double _containerWidth = 0;
    private double _lastSizeScale = 1.0;

    private string _computedHexSize = "100px";
    private string _computedHalfGap = "2.50px";
    private string _computedRowMargin = "-18px";

    // ─── Lifecycle ─────────────────────────────────────────────────────────────

    protected override void OnParametersSet()
    {
        _rows = BuildRows(Cells, RowLayout);

        // Re-calcula si el SizeScale cambió desde afuera (ej: slider)
        bool scaleChanged = Math.Abs(SizeScale - _lastSizeScale) > 0.001;
        if (scaleChanged && _containerWidth > 0)
        {
            _lastSizeScale = SizeScale;
            RecalcFromWidth(_containerWidth);
        }

        if (!AutoSize)
        {
            if (double.TryParse(HexSize.Replace("px", ""),
                System.Globalization.NumberStyles.Any,
                System.Globalization.CultureInfo.InvariantCulture, out double w))
                ApplySizes(w * SizeScale);
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && AutoSize)
        {
            _selfRef = DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("hexGridInterop.observe", _gridRef, _selfRef);
        }
    }

    // ─── ResizeObserver callback ───────────────────────────────────────────────

    [JSInvokable]
    public async Task OnContainerResized(double containerWidthPx)
    {
        _containerWidth = containerWidthPx;
        RecalcFromWidth(containerWidthPx);
        StateHasChanged();

        if (OnGeometryChanged.HasDelegate)
        {
            var centers = ComputeHexCenters(containerWidthPx);
            await OnGeometryChanged.InvokeAsync(
                new BoardGeometry(_hexSizePx, _gapPx, containerWidthPx, centers));
        }
    }

    // ─── Cálculo de tamaños ────────────────────────────────────────────────────

    private void RecalcFromWidth(double containerWidthPx)
    {
        int maxCols = RowLayout.Max();
        double usable = containerWidthPx * 0.90;
        double hexSize = usable / (maxCols * (1 + GapRatio)) * SizeScale;
        ApplySizes(Math.Clamp(hexSize, 30, 200));
    }

    private void ApplySizes(double hexSize)
    {
        _hexSizePx = hexSize;
        _gapPx = hexSize * GapRatio;

        double rowMargin = _gapPx * 0.866 - hexSize * 0.2887;

        var fmt = System.Globalization.CultureInfo.InvariantCulture;
        _computedHexSize = $"{hexSize.ToString("F2", fmt)}px";
        _computedHalfGap = $"{(_gapPx / 2).ToString("F2", fmt)}px";
        _computedRowMargin = $"{rowMargin.ToString("F2", fmt)}px";
    }

    // ─── Centros de los hexágonos ──────────────────────────────────────────────

    /// <summary>
    /// Calcula la posición (cx, cy) del centro de cada hexágono en píxeles,
    /// relativa a la esquina superior-izquierda del elemento .hex-grid.
    ///
    /// La fórmula tiene en cuenta:
    ///   - El padding lateral del CSS (5% de cada lado = 10% total)
    ///   - El indent de cada fila según RowLayout
    ///   - El gap entre hexágonos
    ///   - El espaciado vertical entre filas
    /// </summary>
    private List<(double X, double Y)> ComputeHexCenters(double containerWidth)
    {
        var centers = new List<(double X, double Y)>();
        double H = _hexSizePx * 1.1547;
        double pad = containerWidth * 0.05;   // coincide con padding: 0 5% del CSS
        int maxCols = RowLayout.Max();

        double cy = H / 2;   // primera fila: centro en mitad de la altura del hex

        for (int r = 0; r < RowLayout.Length; r++)
        {
            int rowCols = RowLayout[r];
            double indent = (maxCols - rowCols) / 2.0 * (_hexSizePx + _gapPx);

            for (int c = 0; c < rowCols; c++)
            {
                double cx = pad + indent + _gapPx / 2 + c * (_hexSizePx + _gapPx) + _hexSizePx / 2;
                centers.Add((cx, cy));
            }

            // El espaciado vertical entre filas = (hexSize + gap) * sin(60°) = * 0.866
            if (r < RowLayout.Length - 1)
                cy += (_hexSizePx + _gapPx) * 0.866;
        }

        return centers;
    }

    // ─── Indent por fila ──────────────────────────────────────────────────────

    private string GetRowIndent(int rowCols)
    {
        int maxCols = RowLayout.Max();
        double hexPlusGap = _hexSizePx + _gapPx;
        double indent = (maxCols - rowCols) / 2.0 * hexPlusGap;
        return $"{indent.ToString("F2", System.Globalization.CultureInfo.InvariantCulture)}px";
    }

    // ─── Construcción de filas ─────────────────────────────────────────────────

    private static List<List<HexCell>> BuildRows(List<HexCell> cells, int[] rowLayout)
    {
        var rows = new List<List<HexCell>>();
        int index = 0;

        foreach (int colCount in rowLayout)
        {
            if (index >= cells.Count) break;
            var row = cells.Skip(index).Take(colCount).ToList();
            if (row.Count == 0) break;
            rows.Add(row);
            index += row.Count;
        }

        return rows;
    }

    // ─── Selección ─────────────────────────────────────────────────────────────

    private bool IsSelected(HexCell cell) => _selectedIds.Contains(cell.Id);

    private async Task SelectCell(HexCell cell)
    {
        if (!MultiSelect)
        {
            bool wasSelected = _selectedIds.Contains(cell.Id);
            _selectedIds.Clear();
            if (!wasSelected) _selectedIds.Add(cell.Id);
        }
        else
        {
            if (!_selectedIds.Add(cell.Id))
                _selectedIds.Remove(cell.Id);
        }

        if (OnCellClick.HasDelegate) await OnCellClick.InvokeAsync(cell);
        if (OnSelectionChanged.HasDelegate) await OnSelectionChanged.InvokeAsync(
            Cells.Where(c => _selectedIds.Contains(c.Id)).ToList());
    }

    // ─── Dispose ───────────────────────────────────────────────────────────────

    public async ValueTask DisposeAsync()
    {
        if (AutoSize)
        {
            try { await JS.InvokeVoidAsync("hexGridInterop.unobserve", _gridRef); }
            catch (JSDisconnectedException) { }
        }
        _selfRef?.Dispose();
    }
}
