@inherits LayoutComponentBase
@using MudBlazor
@inject Personalizacion_Pagina Config

<MudThemeProvider />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>
    <main>
        <div class="top-row px-4">
            <a href="https://docs.google.com/document/d/1dZM7HzrVrnviHnmxv2z44TiXcDAsq8W00hI1Tz1sSoY/edit?tab=t.0" target="_blank">Documento importante</a>
            <button class="settings-button-top-row" @onclick="TOGGLE_SETTINGS">
                <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" fill="currentColor" class="bi bi-gear" viewBox="0 0 16 16">
                    <path d="M8 4.754a3.246 3.246 0 1 0 0 6.492 3.246 3.246 0 0 0 0-6.492M5.754 8a2.246 2.246 0 1 1 4.492 0 2.246 2.246 0 0 1-4.492 0" />
                    <path d="M9.796 1.343c-.527-1.79-3.065-1.79-3.592 0l-.094.319a.873.873 0 0 1-1.255.52l-.292-.16c-1.64-.892-3.433.902-2.54 2.541l.159.292a.873.873 0 0 1-.52 1.255l-.319.094c-1.79.527-1.79 3.065 0 3.592l.319.094a.873.873 0 0 1 .52 1.255l-.16.292c-.892 1.64.901 3.434 2.541 2.54l.292-.159a.873.873 0 0 1 1.255.52l.094.319c.527 1.79 3.065 1.79 3.592 0l.094-.319a.873.873 0 0 1 1.255-.52l.292.16c1.64.893 3.434-.902 2.54-2.541l-.159-.292a.873.873 0 0 1 .52-1.255l.319-.094c1.79-.527 1.79-3.065 0-3.592l-.319-.094a.873.873 0 0 1-.52-1.255l.16-.292c.893-1.64-.902-3.433-2.541-2.54l-.292.159a.873.873 0 0 1-1.255-.52zm-2.633.283c.246-.835 1.428-.835 1.674 0l.094.319a1.873 1.873 0 0 0 2.693 1.115l.291-.16c.764-.415 1.6.42 1.184 1.185l-.159.292a1.873 1.873 0 0 0 1.116 2.692l.318.094c.835.246.835 1.428 0 1.674l-.319.094a1.873 1.873 0 0 0-1.115 2.693l.16.291c.415.764-.42 1.6-1.185 1.184l-.291-.159a1.873 1.873 0 0 0-2.693 1.116l-.094.318c-.246.835-1.428.835-1.674 0l-.094-.319a1.873 1.873 0 0 0-2.692-1.115l-.292.16c-.764.415-1.6-.42-1.184-1.185l.159-.291A1.873 1.873 0 0 0 1.945 8.93l-.319-.094c-.835-.246-.835-1.428 0-1.674l.319-.094A1.873 1.873 0 0 0 3.06 4.377l-.16-.292c-.415-.764.42-1.6 1.185-1.184l.292.159a1.873 1.873 0 0 0 2.692-1.115z" />
                </svg>
                @* el svg es el icono de settings*@
            </button>
        </div>

        <article class="content px-4">
            @Body
        </article>
    </main>
</div>
@*─────────────────────────────────────────────────Settings Pop-up─────────────────────────────────────────────────*@
@if (Mostrando_Settings==true)
{
    <div class="popup-overlay" @onclick="CLOSE_SETTINGS">
        <div class="popup" @onclick:stopPropagation="true">
            <div class="popup-header">
                <h3>Settings</h3>
                <button class="close-btn" @onclick="CLOSE_SETTINGS">✕</button>
            </div>
            <div class="popup-body">

                <MudSwitch @bind-Value="Config.Dark_Mode" Color="Color.Dark" UncheckedColor="Color.Default"> Dark_Mode</MudSwitch>

                <label>Notificaciones</label>
                <input type="checkbox" checked />

                <label>HexSize</label>
                Value: @(Math.Round((1 - Config.Valor_Gapratio) * 100))%
                <div style="transform:scaleX(-1);"> @* espeja todo adentro de </div> con respecto al axis X*@
                    <MudSlider @bind-Value="Config.Valor_Gapratio" Step="0.01" Min="0" Max="0.9" Color="Color.Info"></MudSlider>
                </div>
                
                @* El slider cambia la separacion entre casillas, pero como estas siempre tienen que quedar alineadas, por consecuencia, se cambia el tamaño de los casillas*@
                @* Comentario desactualizado*@
                @* slider para la separacion entre casillas, scrapeado por posibles quilombos con las casas *@
                @* Comentario desactualizado*@

                <label>BoardScale</label>
                <MudSlider @bind-Value="Config.Valor_SizeScale" Step="0.01" Min="0" Max="1.5" Color="Color.Info"> Value: @Config.Valor_SizeScale.ToString()</MudSlider>
                @*  slider para el multiplicador de escalado de tamaño del  *@
            </div>
        </div>
    </div>
}
@*─────────────────────────────────────────────────Settings Pop-up─────────────────────────────────────────────────*@

@code
{
    /*----------Pop-up-----------*/
    private bool Mostrando_Settings;
    void TOGGLE_SETTINGS()
    {
        Mostrando_Settings = !Mostrando_Settings;
        //Mostrando_Settings = Mostrando_Settings negado;
    }
    private void CLOSE_SETTINGS()
    {
        Mostrando_Settings = false;
    }
    /*----------Pop-up-----------*/
}